<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:orientation="vertical">

    <!-- Custom Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/profileToolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/white"
        app:navigationIcon="@drawable/home_24px"
        app:title="My Profile"
        app:titleTextColor="#FF8F00" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Profile Image Section -->
            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="16dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/profileImage"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:background="@drawable/circle_bg"
                    android:padding="4dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/account_circle_24px"
                    app:shapeAppearanceOverlay="@style/CircleImage" />

                <ImageView
                    android:id="@+id/btnChangePicture"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_alignBottom="@id/profileImage"
                    android:layout_alignEnd="@id/profileImage"
                    android:background="@drawable/circle_bg"
                    android:backgroundTint="#FF8F00"
                    android:padding="8dp"
                    android:src="@drawable/home_24px"
                    android:visibility="gone" />
            </RelativeLayout>

            <TextView
                android:id="@+id/btnEditProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="24dp"
                android:padding="8dp"
                android:text="Edit Profile"
                android:textColor="#FF8F00"
                android:textStyle="bold" />

            <!-- Fields -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Full Name" android:textColor="#888888" android:textSize="12sp" />
            <EditText
                android:id="@+id/editName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:enabled="false"
                android:hint="Your Name"
                android:paddingVertical="12dp"
                android:textColor="@android:color/black" />
            <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginBottom="16dp" android:background="#EEEEEE" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Email Address" android:textColor="#888888" android:textSize="12sp" />
            <EditText
                android:id="@+id/editEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:enabled="false"
                android:hint="Email"
                android:paddingVertical="12dp"
                android:textColor="@android:color/black" />
            <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginBottom="16dp" android:background="#EEEEEE" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mobile Number" android:textColor="#888888" android:textSize="12sp" />
            <EditText
                android:id="@+id/editMobile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:enabled="false"
                android:hint="Mobile No."
                android:inputType="phone"
                android:paddingVertical="12dp"
                android:textColor="@android:color/black" />
            <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginBottom="16dp" android:background="#EEEEEE" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="University ID" android:textColor="#888888" android:textSize="12sp" />
            <EditText
                android:id="@+id/editUniversityId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:enabled="false"
                android:hint="ID Card No."
                android:paddingVertical="12dp"
                android:textColor="@android:color/black" />
            <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginBottom="24dp" android:background="#EEEEEE" />

            <Button
                android:id="@+id/btnUpdate"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="#FF8F00"
                android:text="Save Changes"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/sectionPayment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:background="#F9F9F9"
                android:padding="16dp"
                android:text="Payment Methods"
                android:textColor="@android:color/black" />

            <TextView
                android:id="@+id/sectionRateUs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:background="#F9F9F9"
                android:padding="16dp"
                android:text="Rate Us"
                android:textColor="@android:color/black" />

            <Button
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:backgroundTint="#FF8F00"
                android:text="Logout"
                android:textColor="@android:color/white" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
